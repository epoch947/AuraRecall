# AuraRecall — Environment Variables
# Copy this file to .env for local development and set all values.
# Paste the same keys into: Vercel Dashboard → Project → Settings → Environment Variables

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_MOCK_API=false

# ── OpenAI (gpt-4o-mini for echo generation, gpt-4o for patterns, DALL-E 3 for images)
OPENAI_API_KEY=

# ── Vercel Postgres ───────────────────────────────────────────────────────────
# Get both from: Vercel Dashboard → Storage → your Postgres DB → .env.local tab
POSTGRES_PRISMA_URL=         # pooled connection string — used by the app at runtime
POSTGRES_URL_NON_POOLING=    # direct connection string — used by prisma db push / migrate
