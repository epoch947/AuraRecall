generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PublicEcho {
  id         String   @id @default(uuid())
  color      String   // Semantic color (hex or HSL) — never raw user text
  insight    String   // AI-generated Socratic question
  weather    String   // Weather condition string
  resonances Int      @default(0) // Community ripple count
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
