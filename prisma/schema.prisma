generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PublicEcho {
  id         String   @id @default(uuid())
  color      String   // The semantic color (hex or HSL)
  insight    String   // AI-generated Socratic question
  weather    String   // Weather condition string
  resonances Int      @default(0) // Community ripple count
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
